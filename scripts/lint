#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

echo "==> Running lints"

# Build the list of Gradle lint tasks not covered by a locally installed
# formatter, then run them in a single invocation so we pay buildSrc
# compilation and project configuration once instead of per language.
gradle_tasks=()

if command -v ktfmt &> /dev/null; then
    echo "==> Checking ktfmt"
    ./scripts/kotlin-format --dry-run --set-exit-if-changed
else
    gradle_tasks+=(lintKotlin)
fi

if command -v palantir-java-format &> /dev/null; then
    echo "==> Checking palantir-java-format"
    ./scripts/java-format --dry-run --set-exit-if-changed
else
    gradle_tasks+=(lintJava)
fi

if [[ "${#gradle_tasks[@]}" -gt 0 ]]; then
    echo "==> Running gradlew ${gradle_tasks[*]}"
    ./gradlew "${gradle_tasks[@]}"
fi
